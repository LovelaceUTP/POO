        <mxCell id="xdYaj9bOOvHgz-sj0mkT-25" value="CONSTRAINT chk_nombreUsuario CHECK(nombre!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, nombre) = 0),&lt;br&gt;&#x9;CONSTRAINT chk_apellidosUsuario CHECK(apellidos!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, apellidos) = 0),&lt;br&gt;&#x9;CONSTRAINT chk_cargoUsuario CHECK(cargo!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, cargo) = 0),&lt;br&gt;&#x9;CONSTRAINT chk_telefonoUsuario CHECK(telefono!=&#39;&#39;),&lt;br&gt;&#x9;CONSTRAINT chk_correoUsuario CHECK (correo LIKE &#39;%_@__%.__%&#39; AND correo != &#39;&#39;)" style="shape=note;size=20;fontFamily=Ubuntu Mono;align=left;fontSize=5;horizontal=1;fontColor=default;whiteSpace=wrap;html=1;fontStyle=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DUbuntu%2BMono;" parent="1" vertex="1">
          <mxGeometry x="2040" y="50" width="330" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xdYaj9bOOvHgz-sj0mkT-32" value="&lt;div&gt;CREATE TABLE Contacto(&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;idContacto&amp;nbsp; INT IDENTITY(1,1) PRIMARY KEY,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;personalID VARCHAR(15) NOT NULL UNIQUE,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;fiscalID VARCHAR(15) NOT NULL UNIQUE,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;nombre NVARCHAR(150) NOT NULL,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;apellidos&amp;nbsp; NVARCHAR(150) NOT NULL,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;cargo&amp;nbsp; NVARCHAR(150) NOT NULL,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;telefono VARCHAR(15) NOT NULL,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;correo VARCHAR(255) UNIQUE,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;-- condiciones&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;CONSTRAINT chk_nombreContacto CHECK(nombre!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, nombre) = 0),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;CONSTRAINT chk_apellidoContacto CHECK(apellidos!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, apellidos) = 0),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;CONSTRAINT chk_cargoContacto CHECK(cargo!=&#39;&#39; AND PATINDEX(&#39;%[0-9]%&#39;, cargo) = 0),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;CONSTRAINT chk_telefonoContacto CHECK(telefono!=&#39;&#39;),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;CONSTRAINT chk_correoContacto CHECK (correo LIKE &#39;%_@__%.__%&#39; AND correo != &#39;&#39;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;" style="shape=note;size=20;fontFamily=Ubuntu Mono;align=left;fontSize=5;horizontal=1;fontColor=default;whiteSpace=wrap;html=1;fontStyle=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DUbuntu%2BMono;" parent="1" vertex="1">
          <mxGeometry x="2040" y="698" width="270" height="110" as="geometry" />
        </mxCell>
